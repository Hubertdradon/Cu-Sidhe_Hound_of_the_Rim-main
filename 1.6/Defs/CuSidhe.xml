<Defs>

	<ThingDef ParentName="AnimalThingBase">
		<defName>CuSidhe</defName>
		<label>Cu Sidhe</label>
		<description>Cu Sidhe is a canine that was an experiment on creating a perfect canine after the successful creation of wargs, it contains DNA of such dog breeds as the Tibetan Mastiff, Kangal, Bankhar Dog, Great Pyrenees, Leonberger, and so forth. However, like the aforementioned wargs and alphabeavers, Cu Sidhe were accidentally distributed throughout the RimWorld wilderness.</description>
		<statBases>
			<MoveSpeed>5.0</MoveSpeed>
			<MarketValue>1750</MarketValue>
			<ComfyTemperatureMin>-85</ComfyTemperatureMin>
			<ComfyTemperatureMax>40</ComfyTemperatureMax>
			<FilthRate>3</FilthRate>
			<Wildness>0.70</Wildness>
		</statBases>
		<race>
			<animalType>Canine</animalType>
			<body>QuadrupedAnimalWithPawsAndTail</body>
			<predator>true</predator>
			<baseBodySize>4</baseBodySize>
			<baseHungerRate>0.75</baseHungerRate>
			<baseHealthScale>4</baseHealthScale>
			<maxPreyBodySize>99999</maxPreyBodySize>
			<foodType>CarnivoreAnimal, OvivoreAnimal</foodType>
			<leatherDef>Leather_Wolf</leatherDef>
			<gestationPeriodDays>15</gestationPeriodDays>
			<nameOnTameChance>1</nameOnTameChance>
			<trainability>Advanced</trainability>
			<manhunterOnTameFailChance>0.30</manhunterOnTameFailChance>
			<manhunterOnDamageChance>1</manhunterOnDamageChance>
			<nuzzleMtbHours>18</nuzzleMtbHours>
			<lifeExpectancy>50</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.2</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.5</minAge>
					<soundWounded>Pawn_Warg_Wounded</soundWounded>
					<soundDeath>Pawn_Warg_Death</soundDeath>
					<soundCall>Pawn_Warg_Call</soundCall>
					<soundAngry>Pawn_Warg_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
			<soundEating>PredatorLarge_Eat</soundEating>
			<headPosPerRotation>
				<li>(0.0, 0, 0.2)</li>
				<li>(0.3, 0, 0.03)</li>
				<li>(0.0, 0, -0.16)</li>
				<li>(-0.3, 0, 0.03)</li>
			</headPosPerRotation>
		</race>
		<tradeTags>
			<li>AnimalUncommon</li>
			<li>AnimalFighter</li>
		</tradeTags>
		<tools>
			<li>
				<label>left claw</label>
				<labelNoLocation>claw</labelNoLocation>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>21</power>
				<armorPenetration>0.5</armorPenetration>
				<cooldownTime>1.3</cooldownTime>
				<linkedBodyPartsGroup>FrontLeftPaw</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>right claw</label>
				<labelNoLocation>claw</labelNoLocation>
				<capacities>
					<li>Scratch</li>
				</capacities>
				<power>21</power>
				<armorPenetration>0.5</armorPenetration>
				<cooldownTime>1.3</cooldownTime>
				<linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>14</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>razorfangs</label>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>25</power>
				<armorPenetration>0.5</armorPenetration>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.9</chanceFactor>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>15</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>17</power>
				<armorPenetration>0.5</armorPenetration>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
		</tools>
		<modExtensions>
			<li  MayRequire="Owlchemist.GiddyUp" Class="GiddyUp.Mountable"/>
			<li MayRequire="Owlchemist.GiddyUp" Class="GiddyUp.DrawingOffset">
				<eastOffset>0.2,0,0.5</eastOffset>
				<westOffset>-0.2,0,0.5</westOffset>
				<northOffset>0,0,0</northOffset>
				<southOffset>0,0,0</southOffset>
			</li>
		</modExtensions>
	</ThingDef>

	<PawnKindDef ParentName="AnimalKindBase">
		<defName>CuSidhe</defName>
		<label>cu sidhe</label>
		<race>CuSidhe</race>
